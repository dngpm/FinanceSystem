<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Trợ Lý Tài Chính</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @if (ViewData["AuthPage"] == null)
    {
    <nav class="navbar navbar-expand-lg navbar-dark shadow-sm fixed-top">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                <i class="fa-solid fa-chart-line me-2"></i>
                Trợ Lý Tài Chính
            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarNav"
                    aria-controls="navbarNav"
                    aria-expanded="false"
                    aria-label="Mo menu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- 3 menu công cụ — ẩn khi ở trang Login/Register -->
            @if (User.Identity?.IsAuthenticated == true && ViewData["MinimalNav"] == null)
            {
            <ul class="navbar-nav navbar-tools-always d-flex flex-row">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Loan" asp-action="Index">
                        <i class="fa-solid fa-house-chimney me-1"></i>
                        <span class="d-none d-md-inline">Công cụ tính toán khoản vay</span>
                        <span class="d-inline d-md-none">Vay</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Savings" asp-action="Index">
                        <i class="fa-solid fa-piggy-bank me-1"></i>
                        <span class="d-none d-md-inline">Công cụ tính toán tiết kiệm</span>
                        <span class="d-inline d-md-none">Tiết kiệm</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="CashFlow" asp-action="Index">
                        <i class="fa-solid fa-wallet me-1"></i>
                        <span class="d-none d-md-inline">Phân tích dòng tiền</span>
                        <span class="d-inline d-md-none">CashFlow</span>
                    </a>
                </li>
            </ul>
            }

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">

                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false"
                               style="color:#fbbf24 !important;">
                                <i class="fa-solid fa-shield-halved me-1"></i>
                                Admin
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item" asp-controller="Admin" asp-action="Users">
                                        <i class="fa-solid fa-users me-2"></i>Quản lý người dùng
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Admin" asp-action="UserActivity">
                                        <i class="fa-solid fa-clock-rotate-left me-2"></i>Lịch sử hoạt động
                                    </a>
                                </li>

                            </ul>
                        </li>
                    }

                    @if (User.Identity?.IsAuthenticated == true && ViewData["MinimalNav"] == null)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Profile">
                                <i class="fa-solid fa-user me-1"></i>
                                @(User.Identity.Name ?? "Hồ sơ")
                            </a>
                        </li>
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="nav-link logout-btn">
                                    <i class="fa-solid fa-right-from-bracket me-1"></i>
                                    Đăng xuất
                                </button>
                            </form>
                        </li>
                    }
                    else if (!User.Identity?.IsAuthenticated == true || ViewData["MinimalNav"] != null)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">
                                <i class="fa-solid fa-right-to-bracket me-1"></i>
                                Đăng nhập / Đăng ký
                            </a>
                        </li>
                    }
                </ul>

                <!-- Theme toggle button -->
                <button id="theme-toggle" type="button" title="Chuyển chế độ sáng/tối" aria-label="Chuyển chế độ sáng/tối">
                    <i class="fa-solid fa-sun" id="theme-icon"></i>
                    <span id="theme-label">Sáng</span>
                </button>
            </div>
        </div>
    </nav>

    @if (User.IsInRole("Guest"))
    {
        <div class="guest-banner">
            <div class="guest-banner-inner">
                <span class="guest-banner-icon"><i class="fa-solid fa-circle-info"></i></span>
                <span class="guest-banner-text">
                    Bạn đang dùng ở chế độ khách — kết quả tính toán sẽ không được lưu lại.
                    <a asp-controller="Account" asp-action="Register" class="guest-banner-link">Tạo tài khoản miễn phí</a>
                    để lưu lịch sử và theo dõi các khoản vay, tiết kiệm của bạn bất cứ lúc nào.
                </span>
                <button class="guest-banner-close" onclick="this.closest('.guest-banner').style.display='none'" aria-label="Đóng">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
        </div>
    }

    }

    <main class="main-content">
        <div class="container-fluid px-4">
            @RenderBody()
        </div>
    </main>

    <footer class="footer">
        <h5>Trợ Lý Tài Chính</h5>
        <div>Hệ thống tính lãi vay, tiết kiệm và phân tích dòng tiền.</div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        (function () {
        var btn = document.getElementById('theme-toggle');
        var icon = document.getElementById('theme-icon');
        var label = document.getElementById('theme-label');

        function applyTheme(isLight) {
        if (isLight) {
        document.body.classList.add('light-mode');
        icon.className = 'fa-solid fa-moon';
        label.textContent = 'Tối';
        } else {
        document.body.classList.remove('light-mode');
        icon.className = 'fa-solid fa-sun';
        label.textContent = 'Sáng';
        }
        }

        // Restore saved preference
        var saved = localStorage.getItem('theme');
        applyTheme(saved === 'light');

        btn.addEventListener('click', function () {
        var isLight = !document.body.classList.contains('light-mode');
        applyTheme(isLight);
        localStorage.setItem('theme', isLight ? 'light' : 'dark');
        });
        })();
    </script>
</body>
</html>
