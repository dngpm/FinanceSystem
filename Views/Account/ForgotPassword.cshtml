@{
    ViewData["Title"] = "Quên mật khẩu";
    ViewData["AuthPage"] = true;
}

<main class="login-screen">
    <section class="login-hero">
        <div class="login-brand">
            <span class="login-badge">
                <span></span>
                CASHFLOW PRO
            </span>

            <h1>
                Quên mật khẩu?
                <strong>Đặt lại ngay trong vài bước đơn giản</strong>
            </h1>

            <p>
                Nhập địa chỉ email hoặc tên đăng nhập bạn đã dùng để đăng ký. Hệ thống sẽ xác minh
                và cho phép bạn đặt lại mật khẩu ngay lập tức.
            </p>
        </div>

        <div class="login-feature-grid">
            <article>
                <i class="fa-solid fa-shield-halved"></i>
                <h2>Bảo mật</h2>
                <p>Mật khẩu mới được mã hóa an toàn bằng SHA-256 trước khi lưu.</p>
            </article>

            <article>
                <i class="fa-solid fa-bolt"></i>
                <h2>Nhanh chóng</h2>
                <p>Không cần chờ email. Xác minh và đặt lại mật khẩu ngay tức thì.</p>
            </article>

            <article>
                <i class="fa-solid fa-rotate-left"></i>
                <h2>Dễ dàng</h2>
                <p>Chỉ cần nhớ email đăng ký là có thể lấy lại quyền truy cập.</p>
            </article>
        </div>
    </section>

    <section class="login-card" aria-label="Quên mật khẩu">
        <div class="login-card-heading">
            <span>ĐẶT LẠI MẬT KHẨU</span>
            <h2>Xác minh tài khoản</h2>
            <p>Nhập email hoặc tên đăng nhập để tiếp tục.</p>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">
                @TempData["Error"]
            </div>
        }

        <div asp-validation-summary="All" class="login-validation"></div>

        <form asp-action="ForgotPassword" method="post" class="login-form">
            @Html.AntiForgeryToken()

            <div>
                <label>Email hoặc tên đăng nhập</label>
                <input name="email" type="text" autocomplete="username"
                       placeholder="ten@congty.com hoặc nguyen_van_a" />
            </div>

            <button type="submit" class="login-submit">
                <i class="fa-solid fa-magnifying-glass me-2"></i>Xác minh tài khoản
            </button>
        </form>

        <div class="login-register mt-3">
            <span>Nhớ mật khẩu rồi?</span>
            <a asp-action="Login">Quay lại đăng nhập</a>
        </div>
    </section>
</main>
