@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    ViewData["AuthPage"] = true;
}

<main class="login-screen">
    <section class="login-hero">
        <div class="login-brand">
            <span class="login-badge">
                <span></span>
                CASHFLOW PRO
            </span>

            <h1>
                Đặt mật khẩu
                <strong>mới cho tài khoản của bạn</strong>
            </h1>

            <p>
                Tài khoản đã được xác minh. Hãy tạo mật khẩu mới an toàn
                và ghi nhớ để đăng nhập lần sau.
            </p>
        </div>

        <div class="login-feature-grid">
            <article>
                <i class="fa-solid fa-key"></i>
                <h2>Mật khẩu mạnh</h2>
                <p>Nên kết hợp chữ hoa, chữ thường, số và ký tự đặc biệt.</p>
            </article>

            <article>
                <i class="fa-solid fa-eye-slash"></i>
                <h2>Giữ bí mật</h2>
                <p>Không chia sẻ mật khẩu với bất kỳ ai, kể cả quản trị viên.</p>
            </article>

            <article>
                <i class="fa-solid fa-circle-check"></i>
                <h2>Áp dụng ngay</h2>
                <p>Mật khẩu mới có hiệu lực ngay sau khi xác nhận thành công.</p>
            </article>
        </div>
    </section>

    <section class="login-card" aria-label="Đặt lại mật khẩu">
        <div class="login-card-heading">
            <span>ĐẶT LẠI MẬT KHẨU</span>
            <h2>Tạo mật khẩu mới</h2>
            <p>Mật khẩu phải có ít nhất 6 ký tự.</p>
        </div>

        <div asp-validation-summary="All" class="login-validation"></div>

        <form asp-action="ResetPassword" method="post" class="login-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="uid" value="@ViewBag.Uid" />
            <input type="hidden" name="t"   value="@ViewBag.T" />
            <input type="hidden" name="tok" value="@ViewBag.Tok" />

            <div>
                <label>Mật khẩu mới</label>
                <div class="password-field">
                    <input name="newPassword" id="newPassword" type="password"
                           autocomplete="new-password" placeholder="Tối thiểu 6 ký tự" />
                    <button type="button" id="toggleNew">Hiện</button>
                </div>
            </div>

            <div>
                <label>Xác nhận mật khẩu mới</label>
                <div class="password-field">
                    <input name="confirmPassword" id="confirmPassword" type="password"
                           autocomplete="new-password" placeholder="Nhập lại mật khẩu" />
                    <button type="button" id="toggleConfirm">Hiện</button>
                </div>
            </div>

            <!-- Thanh đo độ mạnh mật khẩu -->
            <div class="password-strength-wrap" id="strengthWrap" style="display:none">
                <div class="password-strength-bar">
                    <div id="strengthBar" class="password-strength-fill"></div>
                </div>
                <span id="strengthLabel" class="password-strength-label"></span>
            </div>

            <button type="submit" class="login-submit">
                <i class="fa-solid fa-floppy-disk me-2"></i>Lưu mật khẩu mới
            </button>
        </form>

        <div class="login-register mt-3">
            <span>Muốn thử lại?</span>
            <a asp-action="ForgotPassword">Quay lại</a>
        </div>
    </section>
</main>

@section Scripts {
<script>
document.addEventListener("DOMContentLoaded", function () {
    // Toggle hiện/ẩn mật khẩu
    function bindToggle(inputId, btnId) {
        const inp = document.getElementById(inputId);
        const btn = document.getElementById(btnId);
        if (!inp || !btn) return;
        btn.addEventListener("click", function () {
            const hidden = inp.type === "password";
            inp.type = hidden ? "text" : "password";
            btn.textContent = hidden ? "Ẩn" : "Hiện";
        });
    }
    bindToggle("newPassword", "toggleNew");
    bindToggle("confirmPassword", "toggleConfirm");

    // Thanh đo độ mạnh mật khẩu
    const newPwd = document.getElementById("newPassword");
    const strengthWrap = document.getElementById("strengthWrap");
    const strengthBar  = document.getElementById("strengthBar");
    const strengthLabel = document.getElementById("strengthLabel");

    function getStrength(pwd) {
        let score = 0;
        if (pwd.length >= 6) score++;
        if (pwd.length >= 10) score++;
        if (/[A-Z]/.test(pwd)) score++;
        if (/[0-9]/.test(pwd)) score++;
        if (/[^A-Za-z0-9]/.test(pwd)) score++;
        return score;
    }

    newPwd.addEventListener("input", function () {
        const val = this.value;
        if (!val) { strengthWrap.style.display = "none"; return; }
        strengthWrap.style.display = "flex";
        const score = getStrength(val);
        const levels = [
            { pct: "20%", color: "#ef4444", label: "Rất yếu" },
            { pct: "40%", color: "#f97316", label: "Yếu" },
            { pct: "60%", color: "#eab308", label: "Trung bình" },
            { pct: "80%", color: "#22c55e", label: "Mạnh" },
            { pct: "100%", color: "#16a34a", label: "Rất mạnh" },
        ];
        const lv = levels[Math.min(score - 1, 4)] || levels[0];
        strengthBar.style.width = lv.pct;
        strengthBar.style.background = lv.color;
        strengthLabel.textContent = lv.label;
        strengthLabel.style.color = lv.color;
    });
});
</script>
}
