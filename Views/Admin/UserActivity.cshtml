@using FinanceSystem.Models.Entities
@model List<UserActivityLog>

@{
    ViewData["Title"] = "Lịch Sử Hoạt Động";
    int page = ViewBag.Page;
    int totalPage = ViewBag.TotalPage;
    int total = ViewBag.Total;
    Guid? userId = ViewBag.UserId;
    string? module = ViewBag.Module;
    var users = (IEnumerable<dynamic>)ViewBag.Users;
    var modules = (IEnumerable<string>)ViewBag.Modules;
    var stats = ViewBag.Stats as UserActivityStats;

    string TimeAgo(DateTime dt)
    {
        var diff = DateTime.Now - dt;
        if (diff.TotalMinutes < 1) return "vừa xong";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} phút trước";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} giờ trước";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays} ngày trước";
        return dt.ToString("dd/MM/yyyy HH:mm");
    }

    string GetDisplayModule(string rawModule)
    {
        return rawModule switch
        {
            "Account" => "Tài khoản",
            "CashFlow" => "Phân tích dòng tiền",
            "Quản trị" => "Quản trị hệ thống (Admin)",
            _ => rawModule
        };
    }

    // Màu nền badge (đã làm nhạt cho 2 badge đặc biệt)
    string GetBadgeBgColor(string displayModule)
    {
        return displayModule switch
        {
            "Quản trị hệ thống (Admin)" => "#FFF3CD",      // vàng nhạt
            "Phân tích dòng tiền" => "#EDE9FE",      // tím nhạt
            _ => ModuleColor(displayModule) + "33"         // các module khác: pha trong suốt 20%
        };
    }

    // Màu chữ badge (đậm hơn nền)
    string GetBadgeTextColor(string displayModule)
    {
        return displayModule switch
        {
            "Quản trị hệ thống (Admin)" => "#B8860B",      // vàng đậm
            "Phân tích dòng tiền" => "#5B21B6",      // tím đậm
            "Home" => "#000000",
            _ => ModuleColor(displayModule)
        };
    }

    string ModuleIcon(string displayModule) => displayModule switch
    {
        "Tính khoản vay" => "fa-house-chimney",
        "Tiết kiệm" => "fa-piggy-bank",
        "Phân tích dòng tiền" => "fa-wallet",
        "Dịch vụ" => "fa-file-contract",
        "Tài khoản" => "fa-user",
        "Quản trị hệ thống (Admin)" => "fa-shield-halved",
        _ => "fa-circle-dot"
    };

    string ModuleColor(string displayModule) => displayModule switch
    {
        "Tính khoản vay" => "#ef4444",
        "Tiết kiệm" => "#10b981",
        "Phân tích dòng tiền" => "#8B5CF6",   // tím gốc (dùng cho các module khác tham chiếu)
        "Dịch vụ" => "#f59e0b",
        "Tài khoản" => "#3b82f6",
        "Quản trị hệ thống (Admin)" => "#8B5CF6",   // không dùng trực tiếp nữa
        _ => "#6b7280"
    };
}

<div class="container page-shell">
    <section class="tool-intro" style="margin-bottom: 24px;">
        <div>
            <span class="eyebrow">Quản trị hệ thống</span>
            <h1><i class="fa-solid fa-clock-rotate-left me-2"></i>Lịch Sử Hoạt Động</h1>
            <p>Theo dõi người dùng đã sử dụng tính năng gì, lúc nào và truy cập gần nhất khi nào.</p>
        </div>
        <aside class="example-box" style="display:flex;flex-direction:column;gap:10px;">
            <a asp-action="Users" class="btn btn-outline-secondary btn-sm">
                <i class="fa-solid fa-users me-1"></i> Quản lý người dùng
            </a>
            <form asp-action="ClearActivity" method="post" class="d-inline"
                  onsubmit="return confirm('Xóa tất cả log cũ hơn 90 ngày?')">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                    <i class="fa-solid fa-trash me-1"></i> Xóa log cũ (&gt;90 ngày)
                </button>
            </form>
        </aside>
    </section>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fa-solid fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body py-3">
            <form asp-action="UserActivity" method="get" class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label small text-muted mb-1">Người dùng</label>
                    <select name="userId" class="form-select form-select-sm">
                        <option value="">- Tất cả người dùng -</option>
                        @foreach (var u in users)
                        {
                            <option value="@u.Id" selected="@(userId.HasValue && userId.Value == (Guid)u.Id ? "selected" : null)">@u.Username</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted mb-1">Tính năng</label>
                    <select name="module" class="form-select form-select-sm">
                        <option value="">- Tất cả tính năng -</option>
                        @{
                            var displayModules = modules
                                .Where(m => m != "Loan" && m != "Savings")
                                .Select(m => new
                                {
                                    RawValue = m,
                                    DisplayName = m switch
                                    {
                                        "Account" => "Tài khoản",
                                        "CashFlow" => "Phân tích dòng tiền",
                                        "Quản trị" => "Quản trị hệ thống (Admin)",
                                        _ => m
                                    }
                                })
                                .Where(dm => dm.DisplayName != "Account" && dm.DisplayName != "CashFlow")
                                .GroupBy(dm => dm.DisplayName)
                                .Select(g => g.First());
                        }
                        @foreach (var item in displayModules)
                        {
                            <option value="@item.RawValue" selected="@(module == item.RawValue ? "selected" : null)">@item.DisplayName</option>
                        }
                    </select>
                </div>
                <div class="col-md-auto">
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="fa-solid fa-filter me-1"></i> Lọc
                    </button>
                    <a asp-action="UserActivity" class="btn btn-outline-secondary btn-sm ms-1">
                        <i class="fa-solid fa-xmark"></i>
                    </a>
                </div>
                <div class="col-md-auto ms-auto">
                    <span class="badge" style="background-color: #0A5CFF;">@total bản ghi</span>
                </div>
            </form>
        </div>
    </div>

    @if (stats != null)
    {
        var filteredModuleCounts = stats.ModuleCounts
            .Where(kv => kv.Key != "Loan" && kv.Key != "Savings" && kv.Key != "Account" && kv.Key != "CashFlow")
            .Select(kv => new
            {
                Raw = kv.Key,
                Display = kv.Key switch
                {
                    "Quản trị" => "Quản trị hệ thống (Admin)",
                    _ => kv.Key
                },
                Count = kv.Value
            })
            .ToList();
        var totalFilteredActions = filteredModuleCounts.Sum(kv => kv.Count);

        <div class="row g-3 mb-4">
            <div class="col-sm-6 col-xl-3">
                <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #6366f1 !important;">
                    <div class="card-body">
                        <p class="text-muted small mb-1">Tổng thao tác</p>
                        <h4 class="fw-bold mb-0">@totalFilteredActions</h4>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #10b981 !important;">
                    <div class="card-body">
                        <p class="text-muted small mb-1">Ngày hoạt động</p>
                        <h4 class="fw-bold mb-0">@stats.ActiveDays ngày</h4>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #f59e0b !important;">
                    <div class="card-body">
                        <p class="text-muted small mb-1">Lần đầu sử dụng</p>
                        <h5 class="fw-bold mb-0">@stats.FirstSeen.ToString("dd/MM/yyyy")</h5>
                        <small class="text-muted">@stats.FirstSeen.ToString("HH:mm")</small>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #3b82f6 !important;">
                    <div class="card-body">
                        <p class="text-muted small mb-1">Truy cập gần nhất</p>
                        <h5 class="fw-bold mb-0">@TimeAgo(stats.LastSeen)</h5>
                        <small class="text-muted">@stats.LastSeen.ToString("dd/MM/yyyy HH:mm")</small>
                    </div>
                </div>
            </div>

            @if (filteredModuleCounts.Any())
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-dark text-white p-3">
                            <h6 class="mb-0"><i class="fa-solid fa-chart-bar me-2"></i>Tính năng sử dụng nhiều nhất - @stats.Username</h6>
                        </div>
                        <div class="card-body">
                            @foreach (var kv in filteredModuleCounts)
                            {
                                var pct = (int)((double)kv.Count / totalFilteredActions * 100);
                                var displayModule = kv.Display;
                                var icon = ModuleIcon(displayModule);
                                var color = displayModule switch
                                {
                                    "Quản trị hệ thống (Admin)" => "#8B5CF6",
                                    "Phân tích dòng tiền" => "#8B5CF6",
                                    _ => ModuleColor(displayModule)
                                };
                                <div class="mb-2">
                                    <div class="d-flex justify-content-between mb-1">
                                        <span class="small">
                                            <i class="fa-solid @icon me-1" style="color:@color"></i>
                                            @displayModule
                                        </span>
                                        <span class="small text-muted">@kv.Count lần (@pct%)</span>
                                    </div>
                                    <div class="progress" style="height:6px;">
                                        <div class="progress-bar" role="progressbar"
                                             style="width:@pct%;background-color:@color;"></div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-dark text-white p-3">
            <h5 class="mb-0">
                <i class="fa-solid fa-list-ul me-2"></i>
                Chi tiết hoạt động
                @if (userId.HasValue)
                {
                    var u = users.FirstOrDefault(x => (Guid)x.Id == userId.Value);
                    if (u != null)
                    {
                        <span class="badge bg-info ms-2">@u.Username</span>
                    }
                }
            </h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive finance-table-wrap">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th class="ps-3" style="width:200px;">Thời gian</th>
                            <th style="width:150px;">Người dùng</th>
                            <th style="width:160px;">Tính năng</th>
                            <th>Hành động</th>
                            <th style="width:60px;">Loại</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var filteredLogs = Model.Where(log => log.Module != "Loan" && log.Module != "Savings").ToList();
                        }
                        @if (!filteredLogs.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-5">
                                    <i class="fa-solid fa-inbox fa-2x d-block mb-2 opacity-25"></i>
                                    Chưa có lịch sử hoạt động nào.
                                </td>
                            </tr>
                        }
                        @foreach (var log in filteredLogs)
                        {
                            var displayModule = GetDisplayModule(log.Module);
                            var displayAction = log.Action;
                            if (log.Module == "Account")
                            {
                                displayAction = "Xem lịch sử hoạt động";
                            }
                            else if (log.Module == "CashFlow")
                            {
                                displayAction = "Phân tích dòng tiền";
                            }
                            else if (log.Module == "Home")
                            {
                                displayAction = "Vào trang chủ";
                            }
                            var badgeBg = GetBadgeBgColor(displayModule);
                            var badgeColor = GetBadgeTextColor(displayModule);
                            <tr>
                                <td class="ps-3">
                                    <div class="fw-semibold small">@log.Timestamp.ToString("dd/MM/yyyy")</div>
                                    <div style="font-size:12px;color:#4b5563;">
                                        @log.Timestamp.ToString("HH:mm:ss")
                                        <span class="ms-1" style="color:#6b7280;">(@TimeAgo(log.Timestamp))</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-1">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold flex-shrink-0"
                                             style="width:28px;height:28px;background:rgba(99,102,241,0.15);color:#6366f1;font-size:11px;">
                                            @(log.Username.Length > 0 ? log.Username.Substring(0, 1).ToUpper() : "?")
                                        </div>
                                        <span class="small fw-semibold" style="color:#111827;">@log.Username</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge rounded-pill px-2 py-1" style="background:@badgeBg; color:@badgeColor; font-size:11px; font-weight:600;">
                                        <i class="fa-solid @ModuleIcon(displayModule) me-1"></i>@displayModule
                                    </span>
                                </td>
                                <td>
                                    <span class="small" style="color:#111827;">@displayAction</span>
                                    <div style="font-size:11px;color:#4b5563;">@log.Path</div>
                                </td>
                                <td>
                                    @if (log.HttpMethod == "POST")
                                    {
                                        <span class="badge bg-warning text-dark" style="font-size:10px;">POST</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary" style="font-size:10px;">GET</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (totalPage > 1)
        {
            <div class="card-footer bg-transparent border-0">
                <nav>
                    <ul class="pagination pagination-sm mb-0 justify-content-center">
                        @if (page > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" asp-action="UserActivity"
                                       asp-route-page="@(page - 1)" asp-route-userId="@userId" asp-route-module="@module">
                                    <i class="fa-solid fa-chevron-left"></i>
                                </a>
                            </li>
                        }
                        @for (int p = Math.Max(1, page - 2); p <= Math.Min(totalPage, page + 2); p++)
                        {
                            <li class="page-item @(p == page ? "active" : "")">
                                <a class="page-link" asp-action="UserActivity"
                                   asp-route-page="@p" asp-route-userId="@userId" asp-route-module="@module">@p</a>
                            </li>
                        }
                        @if (page < totalPage)
                        {
                            <li class="page-item">
                                <a class="page-link" asp-action="UserActivity"
                                       asp-route-page="@(page + 1)" asp-route-userId="@userId" asp-route-module="@module">
                                    <i class="fa-solid fa-chevron-right"></i>
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>