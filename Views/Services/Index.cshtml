@using FinanceSystem.Models.Entities
@{
    ViewData["Title"] = "Dịch vụ tài chính";
    var rates = ViewBag.Rates as List<InterestRateTable> ?? new();
    var loanRates = rates.Where(r => r.RateType == InterestRateType.Loan).ToList();
    var savingRates = rates.Where(r => r.RateType == InterestRateType.Savings).ToList();
    var canApply = User.Identity?.IsAuthenticated == true && !User.IsInRole("Guest");
}

<div class="container page-shell">
    <section class="tool-intro">
        <div>
            <span class="eyebrow">Dịch vụ của hệ thống</span>
            <h1>Đăng ký vay vốn hoặc gửi tiết kiệm</h1>
            <p>Người dùng gửi yêu cầu, admin xem xét và duyệt hoặc từ chối. Lãi suất hiển thị theo biểu lãi suất hiện tại của hệ thống.</p>
        </div>
        <aside class="example-box">
            <h2>Khách vãng lai</h2>
            <p>Khách chỉ được dùng công cụ tính toán. Để gửi yêu cầu dịch vụ cần có tài khoản.</p>
            @if (!canApply)
            {
                <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary btn-sm">Đăng nhập để sử dụng</a>
            }
        </aside>
    </section>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-dark text-white p-4">
                    <h2 class="mb-0">Dịch vụ vay vốn</h2>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        @foreach (var rate in loanRates)
                        {
                            <div class="col-md-4">
                                <div class="p-3 rounded border h-100 d-flex flex-column">
                                    <strong>@rate.TermLabel</strong>
                                    <div class="fs-4 fw-bold text-danger">@rate.AnnualRatePercent.ToString("N2")%</div>
                                    <small class="text-muted flex-grow-1">@rate.Note</small>
                                    @if (canApply)
                                    {
                                        <a asp-action="Apply" asp-route-type="Loan" asp-route-product="@rate.ProductType" class="btn btn-sm btn-outline-danger mt-3">Gửi yêu cầu</a>
                                    }
                                    else
                                    {
                                        <a asp-controller="Account" asp-action="Login" class="btn btn-sm btn-outline-secondary mt-3">Cần tài khoản</a>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-dark text-white p-4">
                    <h2 class="mb-0">Dịch vụ gửi tiết kiệm</h2>
                </div>
                <div class="card-body p-4">
                    <div class="table-responsive finance-table-wrap">
                        <table class="finance-table">
                            <thead>
                                <tr>
                                    <th>Kỳ hạn</th>
                                    <th>Lãi suất</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var rate in savingRates)
                                {
                                    <tr>
                                        <td>@rate.TermLabel</td>
                                        <td><strong class="text-success">@rate.AnnualRatePercent.ToString("N2")%</strong></td>
                                        <td class="text-end">
                                            @if (canApply)
                                            {
                                                <a asp-action="Apply" asp-route-type="Savings" asp-route-product="@rate.ProductType" class="btn btn-sm btn-outline-success">Gửi yêu cầu</a>
                                            }
                                            else
                                            {
                                                <a asp-controller="Account" asp-action="Login" class="btn btn-sm btn-outline-secondary">Cần tài khoản</a>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    @if (canApply)
                    {
                        <a asp-action="MyRequests" class="btn btn-outline-primary w-100 mt-2">Xem yêu cầu của tôi</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
