@model SavingsResultViewModel

@{
    ViewData["Title"] = "Kết Quả Tiết Kiệm";
}

<style>
    /* Nút "Tính lại" — nổi rõ ở cả chế độ sáng và tối */
    .btn-recalc {
        background-color: #f1f5f9;
        color: #1e293b;
        border: 1.5px solid #94a3b8;
        font-weight: 600;
        transition: background-color 0.2s, color 0.2s, border-color 0.2s;
    }
    .btn-recalc:hover {
        background-color: #e2e8f0;
        color: #0f172a;
        border-color: #64748b;
    }
    [data-bs-theme="dark"] .btn-recalc {
        background-color: #334155;
        color: #f1f5f9;
        border: 1.5px solid #94a3b8;
    }
    [data-bs-theme="dark"] .btn-recalc:hover {
        background-color: #475569;
        color: #ffffff;
        border-color: #cbd5e1;
    }
</style>

<div class="container page-shell">

    <section class="tool-intro" style="margin-bottom: 24px;">
        <div>
            <span class="eyebrow">Kết quả tính toán</span>
            <h1>Tiết kiệm – kết quả chi tiết</h1>
            <p>Xem bên dưới để biết tổng lãi, số tiền thực nhận và lịch nhận lãi từng kỳ.</p>
        </div>
        <aside class="example-box" style="display:flex; flex-direction:column; justify-content:center; gap:12px;">
            <a asp-action="Index" class="btn btn-recalc">
                <i class="fa-solid fa-arrow-left me-1"></i> Tính lại
            </a>
        </aside>
    </section>

    @if (Model.IsEarlyWithdraw)
    {
        <div class="alert alert-warning d-flex gap-3 align-items-start mb-4">
            <i class="fa-solid fa-triangle-exclamation fa-lg mt-1"></i>
            <div>
                <h5 class="mb-1">Bạn đang xem kịch bản rút trước hạn</h5>
                <p class="mb-1">
                    Khi rút sớm, ngân hàng chỉ tính lãi suất không kỳ hạn thay vì lãi suất đã thỏa thuận.
                    Tiền lãi bị mất (so với giữ đến đáo hạn):
                    <strong class="text-danger">@Model.EarlyWithdrawPenalty.ToString("N0") VND</strong>
                </p>
                <p class="mb-0">Số tiền thực nhận khi rút sớm: <strong>@Model.ActualAmountReceived.ToString("N0") VND</strong></p>
            </div>
        </div>
    }

    <!-- Tổng quan 4 chỉ số -->
    <div class="row text-center mb-4">

        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm p-4">
                <h5 class="text-muted mb-2">Tiền gốc gửi vào</h5>
                <h3 class="text-primary">@Model.Principal.ToString("N0")</h3>
                <small class="text-muted">VND</small>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm p-4">
                <h5 class="text-muted mb-2">Tổng tiền lãi</h5>
                <h3 class="text-success">@Model.TotalInterest.ToString("N0")</h3>
                <small class="text-muted">VND</small>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm p-4">
                <h5 class="text-muted mb-2">Thực nhận khi đáo hạn</h5>
                <h3>@Model.ActualAmountReceived.ToString("N0")</h3>
                <small class="text-muted">VND (gốc + lãi)</small>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm p-4">
                <h5 class="text-muted mb-2">
                    Lãi suất thực tế (EIR)
                    <span data-bs-toggle="tooltip"
                          title="EIR là lãi suất thực tế sau khi tính cách nhận lãi. Với lãi kép, EIR cao hơn lãi suất niêm yết."
                          style="cursor:help; font-size:0.75rem; border-bottom:1px dotted">(?)</span>
                </h5>
                <h3 class="text-warning">@Model.EffectiveAnnualRate.ToString("F2")%</h3>
                <small class="text-muted">mỗi năm</small>
            </div>
        </div>

    </div>
    <div class="row mb-4">

        <div class="col-md-6">
            <p>
                <strong>Hình thức nhận lãi:</strong>
                @Model.PaymentTypeDisplayName
            </p>
        </div>

        <div class="col-md-6">
            <p>
                <strong>Tổng số kỳ nhận lãi:</strong>
                @Model.TotalPeriods
            </p>
        </div>

    </div>

    <!-- Lịch nhận lãi -->
    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white p-4">
            <h4 class="mb-0">Lịch nhận lãi chi tiết</h4>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive finance-table-wrap">
                <table class="table table-striped table-hover table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Kỳ</th>
                            <th>Tên kỳ</th>
                            <th>Số dư đầu kỳ</th>
                            <th>Lãi phát sinh</th>
                            <th>Lãi trả ra</th>
                            <th>Số dư cuối kỳ</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Schedule)
                        {
                            <tr>
                                <td>@item.Period</td>
                                <td>@item.PeriodLabel</td>
                                <td>@item.OpeningBalance.ToString("N0")</td>
                                <td class="text-success">@item.InterestEarned.ToString("N0")</td>
                                <td>@item.InterestPaid.ToString("N0")</td>
                                <td><strong>@item.ClosingBalance.ToString("N0")</strong></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-recalc">
            <i class="fa-solid fa-arrow-left me-1"></i> Tính lại
        </a>
    </div>

</div>

@section Scripts {
    <script>
        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
            new bootstrap.Tooltip(el);
        });
    </script>
}
