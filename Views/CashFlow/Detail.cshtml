@model FinanceSystem.Models.Entities.CashFlowHistory
@{
    ViewData["Title"] = "Chi Tiết Phân Tích Dòng Tiền";

    string FmtMoney(decimal v) => v.ToString("N0") + " đ";
    string FmtPct(decimal v)   => (v * 100).ToString("F2") + "%";
    bool isPositive            = Model.NetCashFlow >= 0;
    bool hasInvestment         = Model.InitialInvestment > 0;
}

<style>
    :root {
        --cf-text-primary:   #0f172a;
        --cf-text-secondary: #475569;
        --cf-card-bg:        #ffffff;
        --cf-border:         #e2e8f0;
        --cf-head-bg:        #1e293b;
        --cf-head-fg:        #f1f5f9;
        --cf-green:          #10b981;
        --cf-red:            #ef4444;
        --cf-blue:           #3b82f6;
    }
    [data-bs-theme="dark"] {
        --cf-text-primary:   #f1f5f9;
        --cf-text-secondary: #94a3b8;
        --cf-card-bg:        #1e293b;
        --cf-border:         #334155;
        --cf-head-bg:        #0f172a;
        --cf-head-fg:        #94a3b8;
    }

    .cf-detail-wrap {
        max-width: 860px;
        margin: 0 auto;
        color: var(--cf-text-primary);
    }

    .cf-hero {
        background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%);
        color: #f1f5f9;
        border-radius: 12px;
        padding: 28px 32px 24px;
        margin-bottom: 24px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.18);
    }

    .cf-hero .label  { font-size: 12px; opacity: .7; text-transform: uppercase; letter-spacing:.06em; }
    .cf-hero .value  { font-size: 28px; font-weight: 700; margin: 4px 0 0; }
    .cf-hero .sub    { font-size: 12px; opacity: .65; margin-top: 2px; }

    .cf-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 16px;
        margin-bottom: 24px;
    }

    .cf-stat {
        background: var(--cf-card-bg);
        border: 1px solid var(--cf-border);
        border-radius: 10px;
        padding: 18px 20px;
        box-shadow: 0 1px 6px rgba(0,0,0,.06);
    }
    .cf-stat .s-label { font-size: 11px; color: var(--cf-text-secondary); text-transform: uppercase; letter-spacing:.05em; margin-bottom: 6px; }
    .cf-stat .s-value { font-size: 20px; font-weight: 700; color: var(--cf-text-primary); }
    .cf-stat .s-sub   { font-size: 11px; color: var(--cf-text-secondary); margin-top: 2px; }

    .cf-section {
        background: var(--cf-card-bg);
        border: 1px solid var(--cf-border);
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 20px;
        box-shadow: 0 1px 6px rgba(0,0,0,.06);
    }
    .cf-section-head {
        background: var(--cf-head-bg);
        color: var(--cf-head-fg);
        padding: 12px 20px;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: .04em;
    }
    .cf-section-body { padding: 20px; }

    .cf-row { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid var(--cf-border); }
    .cf-row:last-child { border-bottom: none; padding-bottom: 0; }
    .cf-row .r-label { color: var(--cf-text-secondary); font-size: 13px; }
    .cf-row .r-value { font-weight: 600; font-size: 14px; color: var(--cf-text-primary); text-align: right; }

    .badge-stable  { background: #10b98122; color: #10b981; border-radius: 20px; padding: 4px 12px; font-size: 12px; font-weight: 600; }
    .badge-deficit { background: #ef444422; color: #ef4444; border-radius: 20px; padding: 4px 12px; font-size: 12px; font-weight: 600; }

    .decision-box {
        background: linear-gradient(135deg, #f0fdf4, #dcfce7);
        border-left: 4px solid var(--cf-green);
        border-radius: 8px;
        padding: 14px 18px;
        font-size: 14px;
        color: #166534;
        line-height: 1.6;
    }
    .decision-box.deficit {
        background: linear-gradient(135deg, #fff1f2, #ffe4e6);
        border-left-color: var(--cf-red);
        color: #9f1239;
    }
    [data-bs-theme="dark"] .decision-box        { background: #10b98115; border-color: var(--cf-green); color: #6ee7b7; }
    [data-bs-theme="dark"] .decision-box.deficit { background: #ef444415; border-color: var(--cf-red);   color: #fca5a5; }

    .btn-back {
        display: inline-flex; align-items: center; gap: 6px;
        color: var(--cf-text-secondary); font-size: 13px; text-decoration: none;
        border: 1px solid var(--cf-border); border-radius: 8px; padding: 7px 14px;
        background: var(--cf-card-bg); transition: all .15s;
    }
    .btn-back:hover { color: var(--cf-text-primary); border-color: #94a3b8; }
</style>

<div class="container py-4">
    <div class="cf-detail-wrap">

        @* Back button *@
        <a href="/Account/MyHistory?tab=cashflow" class="btn-back mb-3">
            <i class="fa-solid fa-arrow-left"></i> Quay lại lịch sử
        </a>

        @* Hero *@
        <div class="cf-hero mb-4">
            <div class="row align-items-center g-3">
                <div class="col-auto">
                    <i class="fa-solid fa-chart-line fa-2x opacity-75"></i>
                </div>
                <div class="col">
                    <div class="label">Phân tích dòng tiền</div>
                    <div class="value">@FmtMoney(Math.Abs(Model.NetCashFlow))</div>
                    <div class="sub">Dòng tiền thuần &nbsp;·&nbsp; @Model.CalculatedAt.ToString("HH:mm — dd/MM/yyyy")</div>
                </div>
                <div class="col-auto text-end">
                    @if (Model.HasDeficit)
                    {
                        <span class="badge-deficit"><i class="fa-solid fa-triangle-exclamation me-1"></i>Có thâm hụt</span>
                    }
                    else
                    {
                        <span class="badge-stable"><i class="fa-solid fa-check me-1"></i>Ổn định</span>
                    }
                </div>
            </div>
        </div>

        @* Stat grid *@
        <div class="cf-grid">
            <div class="cf-stat">
                <div class="s-label">Số bút toán</div>
                <div class="s-value">@Model.EntryCount</div>
                <div class="s-sub">bút toán dòng tiền</div>
            </div>
            <div class="cf-stat">
                <div class="s-label">Số kỳ phân tích</div>
                <div class="s-value">@Model.PeriodCount</div>
                <div class="s-sub">kỳ</div>
            </div>
            <div class="cf-stat">
                <div class="s-label">Tổng thu vào</div>
                <div class="s-value" style="color:var(--cf-green);">+@FmtMoney(Model.TotalInflow)</div>
            </div>
            <div class="cf-stat">
                <div class="s-label">Tổng chi ra</div>
                <div class="s-value" style="color:var(--cf-red);">-@FmtMoney(Model.TotalOutflow)</div>
            </div>
        </div>

        @* Detail rows *@
        <div class="cf-section">
            <div class="cf-section-head"><i class="fa-solid fa-sliders me-2"></i>Thông số phân tích</div>
            <div class="cf-section-body">
                <div class="cf-row">
                    <span class="r-label">Dòng tiền thuần</span>
                    <span class="r-value" style="color:@(isPositive ? "var(--cf-green)" : "var(--cf-red)");">
                        @(isPositive ? "+" : "")@FmtMoney(Model.NetCashFlow)
                    </span>
                </div>
                @if (hasInvestment)
                {
                    <div class="cf-row">
                        <span class="r-label">Vốn đầu tư ban đầu</span>
                        <span class="r-value">@FmtMoney(Model.InitialInvestment)</span>
                    </div>
                    <div class="cf-row">
                        <span class="r-label">Lãi suất chiết khấu</span>
                        <span class="r-value">@FmtPct(Model.DiscountRate)</span>
                    </div>
                }
                <div class="cf-row">
                    <span class="r-label">NPV (Giá trị hiện tại thuần)</span>
                    <span class="r-value" style="color:@(Model.NPV >= 0 ? "var(--cf-green)" : "var(--cf-red)");">
                        @(Model.NPV >= 0 ? "+" : "")@Model.NPV.ToString("N0")
                    </span>
                </div>
                @if (Model.IRR != 0)
                {
                    <div class="cf-row">
                        <span class="r-label">IRR (Tỷ suất hoàn vốn nội bộ)</span>
                        <span class="r-value" style="color:var(--cf-blue);">@FmtPct(Model.IRR)</span>
                    </div>
                }
                <div class="cf-row">
                    <span class="r-label">Trạng thái dòng tiền</span>
                    <span class="r-value">
                        @if (Model.HasDeficit)
                        {
                            <span class="badge-deficit"><i class="fa-solid fa-triangle-exclamation me-1"></i>Có thâm hụt</span>
                        }
                        else
                        {
                            <span class="badge-stable"><i class="fa-solid fa-check me-1"></i>Ổn định</span>
                        }
                    </span>
                </div>
                <div class="cf-row">
                    <span class="r-label">Thời điểm phân tích</span>
                    <span class="r-value">@Model.CalculatedAt.ToString("HH:mm — dd/MM/yyyy")</span>
                </div>
            </div>
        </div>

        @* Decision box *@
        @if (!string.IsNullOrEmpty(Model.Decision))
        {
            <div class="cf-section">
                <div class="cf-section-head"><i class="fa-solid fa-lightbulb me-2"></i>Kết luận phân tích</div>
                <div class="cf-section-body">
                    <div class="decision-box @(Model.HasDeficit ? "deficit" : "")">
                        <i class="fa-solid @(Model.HasDeficit ? "fa-triangle-exclamation" : "fa-circle-check") me-2"></i>@Model.Decision
                    </div>
                </div>
            </div>
        }

        @* Re-analyze button *@
        <div class="text-center mt-3">
            <a asp-controller="CashFlow" asp-action="Index" class="btn btn-primary px-4">
                <i class="fa-solid fa-chart-line me-2"></i>Phân tích dòng tiền mới
            </a>
        </div>

    </div>
</div>
